//*** START PROFILE HASH ***//

$(document).ready(function () {


  function removeHash() {
    /* функция удаления хеша */
    var scrollV, scrollH, loc = window.location;
    if ("pushState" in history)
      history.pushState("", document.title, loc.pathname + loc.search);
    else {
      scrollV = document.body.scrollTop;
      scrollH = document.body.scrollLeft;

      loc.hash = "";

      document.body.scrollTop = scrollV;
      document.body.scrollLeft = scrollH;
    }
  }
  /* проверяем есть нужный hash в адресной строке при обновлении  */
  if (document.location.hash) {
    var hashUrl = window.location.hash;
    var urlPath = window.location.pathname;
    if (urlPath == "/") {
      $("body").addClass("stop__scroll");
      $(".modal-overflow").addClass("active");
      $(".modal-container_2").addClass("active");
      $("div" + hashUrl).addClass("active");
      $("div" + hashUrl).parent("form").addClass("active");
    } else {
      $("a.tab__item[href='" + hashUrl + "']").trigger("click");
      $("html").scrollTop(0);
      removeHash();
    }
  };

  /* если hash был изменен и страница не перезагрузилась*/
  window.addEventListener('hashchange', function () {
    var hashUrl = window.location.hash
    if (document.location.hash) {
      $("a.tab__item[href='" + hashUrl + "']").trigger("click");
      $(document).scrollTop(0)
      removeHash();
    };
  });

});

