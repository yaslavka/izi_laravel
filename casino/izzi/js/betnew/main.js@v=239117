function ajaxWin() {

  let currentData = [];

  console.log("yap")

  $.ajax({
    type: "GET",
    url: "/api/ajax/win_list",
    success: function (data) {

      if (JSON.stringify(currentData) === JSON.stringify(data)) {
        return;
      }
      console.log(data)

      currentData = data;

      let maxSlides = 8;

      $(".slide-wins").remove();

      for (let i = 0; i < data.length; i++) {
        const roundedAmount = parseFloat(data[i]['win']).toFixed(0);
        const currency = $(".variables-block-for-js .currency").html();
        let slideHtml = `
          <div class="swiper-slide slide-wins">
            <img class="game" src="${data[i]['image_path']}" alt=""/>

            <div class="mini-desc">
              <span class="name">
                ${data[i]['login']}
              </span>
              <div class="summ">
                <span>${roundedAmount}</span>
                <span>${currency}</span>
              </div>
            </div>
          </div>
        `;

        $(".swiper-wins .swiper-wrapper").prepend(slideHtml);

        if (i === maxSlides - 1) {
          break;
        }
      }
      winsInit()
    },
    error: function () { }
  });
}

