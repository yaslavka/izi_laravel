const maxDuration = 3 * 60 * 1000;

function startTimer() {
    let startTime = localStorage.getItem('startTime');

    if (!startTime) {
        startTime = Date.now();
        localStorage.setItem('startTime', startTime);
    } else {
        startTime = parseInt(startTime, 10);
    }

    function updateElapsedTime() {
        const elapsedTime = Date.now() - startTime;
        const remainingTime = maxDuration - elapsedTime;

        // console.log($("#login").hasClass("active"))
        if (remainingTime <= 0 && !$("#login").hasClass("active")) {
            clearInterval(intervalId);
            localStorage.removeItem('startTime');
            localStorage.setItem('elapsedTime', 0);
          
            close_small();
            modal_container();
            swiperWelcome.init();
            sortWelcomeBonuses()
            $(".modal-container_2").addClass("active");
            $("html").addClass("modal_open");
            $(".modal-win#reg").addClass("active");
            $(".modal-container_2 > form").removeClass("active");
            $(".modal-win#reg").parent("form").addClass("active");
            $(".modal-overflow").addClass("active");
          
            startTimer();
        } else {
            const secondsRemaining = Math.floor(remainingTime / 1000);
            localStorage.setItem('elapsedTime', secondsRemaining);
        }
    }

    const intervalId = setInterval(updateElapsedTime, 1000);
}

