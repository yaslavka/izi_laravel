          if (card_status == "locked") {
            let benefitsHtml = '';

            benefits.forEach(function (benefit) {
              $.each(benefit, function (title, values) {
                benefitsHtml += `<div class="benefit_info locked">`;
                benefitsHtml += `<div class="title">${title}</div>`;

