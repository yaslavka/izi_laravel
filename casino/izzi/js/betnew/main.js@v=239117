            $.each(item, function (title, values) {
              var titleDiv = $('<div class="title"></div>').text(title);
              container.append(titleDiv);

              $.each(values, function (key, value) {
                var rowDiv = $('<div class="row"></div>');
                if (key == 'duration') {
                  var itemKeyDiv = $('<div class="item"></div>').text(bonusDuration);
                } else if (key == 'benefitValue') {
                  var itemKeyDiv = $('<div class="item"></div>').text(bonusPercent);
                } else if (key == 'remain_duration') {
                  var itemKeyDiv = $('<div class="item"></div>').html(bonusRemainingTime);
                }
                if (key == 'remain_duration' && !value) {
                  var itemValueDiv = $('<div class="item"></div>').text(bonusIndefinitely);
                } else if (key == 'remain_duration') {
                  if (!isBenefitsExpired) {
                    var itemValueDiv = $('<div class="item countdown-timer"></div>').text(value);
                  } else {
                    return true;
                  }
                } else {
                  var itemValueDiv = $('<div class="item"></div>').text(value);
                }

                if (typeof itemValueDiv !== 'undefined') {
                  rowDiv.append(itemKeyDiv).append(itemValueDiv);
                  container.append(rowDiv);

                  if (key == 'remain_duration' && value && !isBenefitsExpired) {
                    setTimeout(() => {
                      const [days, hours, minutes] = value.split(':').map(Number);
                      const endTime = new Date().getTime() + (days * 24 * 60 * 60 * 1000) + (hours * 60 * 60 * 1000) + (minutes * 60 * 1000);
                      updateCountdown(itemValueDiv[0], endTime);
                    }, 0);
                  }
                }
              });
            });
          });

          var purchaseTxt = '';
          if (purchase_action) {
            var purchaseTxt = ' ( ' + or + ' ' + purchase_action + ')';
          }

          cardBody = `
          <div>
            <div class="card__error_text" style="display: none;"></div>
            <div class="card unlocked" data-card-id=${card_id}>
              <img src="${card_image}" alt="" class="card__img">
              <div class="card__title">${card_name}</div>
              <div class="card__description">${card_description}</div>
              <div class="card__cost">
                ${price} (${pointsName}): <strong>${card_cost}</strong>
                <br>
                ${purchaseTxt}
              </div>
              <div class="btn btn-filled red activate-card" data-id="${card_id}">` + bonusBuy + `</div>
            </div>
          <div>
        `;

          if (card_status == "bought" && isBenefitsEmpty) {
            cardBody = `<div><div class="card unlocked">
            <img src="${card_image}" alt="" class="card__img">
            <div class="card__title">${card_name}</div>
            <div class="card__description">${card_description}</div>
          </div>`;
          } else if (card_status == "bought" && !benefits_activated_at && !isBenefitsEmpty) {
            cardBody = `<div><div class="card unlocked">
            <img src="${card_image}" alt="" class="card__img">
            <div class="card__title">${card_name}</div>
            <div class="card__description">${card_description}</div>
            <div class="btn btn-filled red activate-benefit" data-id="${card_id}">` + benefitsActivate + `</div>
          </div></div>`;
          } else if (card_status == "bought" && !isBenefitsEmpty) {
            if (!isBenefitsExpired) {
              cardBody = `<div><div class="card unlocked">
              <img src="${card_image}" alt="" class="card__img">
              <div class="card__title">${card_name}</div>
              <div class="card__description">${card_description}</div>
              <div class="btn btn-bordered activate-benefit" data-id="${card_id}">` + benefitsActivated + `</div>
