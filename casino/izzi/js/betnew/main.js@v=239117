function getTransactions(type, limit = 0, offset = 0) {
  $.ajax({
    url: '/api/ajax/transaction.php',
    type: 'POST',
    data: { "type": type, "limit": limit, "offset": offset },
    dataType: 'json',
    success: function (data) {
        // console.log(data.content);
        list = JSON.parse(data.content);
        if (type == 'enter') {
            $('#tab-content__enter .history__body').html('')
            var invCodes = $.map(list, function(item) {
                var typeContent = item.status === 'paid' ? `<span style="color:#1e8517;">${item.type}</span>` : item.type;
                var row = `
                    <tr class="history__row">
                        <th class="history__cell"><span>${historyId}</span> ${item.inv_code}</th>
                        <th class="history__cell"><span>${historyData}</span> ${item.date}</th>
                        <th class="history__cell"><span>${historySum}</span> ${item.sum} ${item.currency}</th>
                        <th class="history__cell"><span>${historySystem}</span> ${item.paysys}</th>
                        <th class="history__cell" ><span>${historyType}</span> ${typeContent}</th>
                    </tr>
                `;
                $('#tab-content__enter .history__body').append(row);
            });
//                $('#tab-content__enter .history__body').html(data.content);
        }
        if (type == 'log') {
            $('#tab-content__log .history__body').html('')
            var invCodes = $.map(list, function(item) {
                var row = `
                    <tr class="history__row">
                        <th class="history__cell"><span>${historyId}</span> ${item.inv_code}</th>
                        <th class="history__cell"><span>${historyData}</span> ${item.date}</th>
                        <th class="history__cell" ><span>${historyType}</span> ${item.type}</th>
                        <th class="history__cell"><span>${historySum}</span> ${item.sum}</th>
                        <th class="history__cell"><span>${historyDeposit}</span> ${item.amount}</th>
                        <th class="history__cell"><span>${historyDescription}</span> ${item.log}</th>
                    </tr>
                `;
                $('#tab-content__log .history__body').append(row);
            });
//                $('#tab-content__log .history__body').html(data.content);
        }
    },
    error: function (xhr, status, error) {
      console.error('Error:', error);
    }
  });
}

var limit = 10;
$('#history .pagination li a.next').on("click", function () {
  var pagination_el = $(this).parent().parent();
  var type = pagination_el.data('type');
  var current_page = pagination_el.data('current_page');
  var page = current_page + 1;
  var offset = page * limit;
  $(this).parent().parent().data('current_page', page);
  pagination_el.find('.prev').show();
  if (offset + limit >= pagination_el.data('total_count')) {
    pagination_el.find('.next').hide();
  }
  getTransactions(type, limit, offset);
});

$('#history .pagination li a.prev').on("click", function () {
  var pagination_el = $(this).parent().parent();
  var type = pagination_el.data('type');
  var current_page = pagination_el.data('current_page');
  var page = current_page - 1;
  var offset = page * limit;
  $(this).parent().parent().data('current_page', page);
  pagination_el.find('.next').show();
  if (page == 0) {
    pagination_el.find('.prev').hide();
  }
  getTransactions(type, limit, offset);
});

