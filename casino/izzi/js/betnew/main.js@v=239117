            parentIds = value.parent_ids,
            benefits_activated_at = value.benefits_activated_at,
            isBenefitsEmpty = value.isBenefitsEmpty,
            isBenefitsExpired = value.isBenefitsExpired,
            isOnCooldown = value.isOnCooldown,
